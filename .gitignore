# Rust build artifacts
/target/
**/*.rs.bk
*.pdb

# Cargo lock for libraries (keep for binaries)
# Cargo.lock is kept for this project since it's a binary

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Local configuration
.claude/settings.local.json

# Debian packaging build artifacts (generated by dpkg-buildpackage)
debian/.cargo/
debian/.debhelper/
debian/target/
debian/tmp/
debian/debhelper-build-stamp
debian/files
debian/*.debhelper.log
debian/*.substvars
debian/tt-toplike/
debian/tt-toplike-egui/

# Generated by build-deb.sh — do not commit
# vendor/ IS committed (offline build reproducibility)
# .cargo/config.toml is written fresh each build to point at vendor/
.cargo/config.toml

# Debug and log files
*.log
/debug/
tmp/

# System files
Thumbs.db
.Spotlight-V100
.Trashes
